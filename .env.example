# Copy this file to .env and fill in values as needed.

# ── IMPORTANT: Proxy (required on cloud/datacenter servers) ───────────────────
#
# Polymarket blocks datacenter and VPS IPs at the network level.
# The dashboard works fine from a residential/home IP without a proxy.
# If you're running on a server, point to a residential HTTP(S) proxy:
#
# HTTPS_PROXY=http://username:password@proxy-host:port
# HTTP_PROXY=http://username:password@proxy-host:port
#
# Providers that work well: Bright Data, Oxylabs, Smartproxy (residential plan)

# ── Optional ───────────────────────────────────────────────────────────────────

# Path to the SQLite database (default: polymarket.db in the working directory)
# DB_PATH=polymarket.db
